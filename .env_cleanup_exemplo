#!/usr/bin/env bash
#
# .env_cleanup
#
# Arquivo de configuração do cleanup_media_manager.sh.
# Copie este arquivo para .env_cleanup e ajuste os valores:
#   cp .env_cleanup_exemplo .env_cleanup
#
# NÃO commite .env_cleanup no Git — ele contém dados sensíveis da sua infraestrutura.

# -----------------------------------------------------------------------------
# Idade das mídias a serem processadas
# -----------------------------------------------------------------------------
DAYS=15

# -----------------------------------------------------------------------------
# Caminhos locais
# -----------------------------------------------------------------------------
HOME_BASE="/home/ubuntu/cleanup"
MEDIA_ROOT="/var/lib/docker/volumes/ticketz-docker-acme_backend_public/_data"

# -----------------------------------------------------------------------------
# Banco de dados PostgreSQL (via docker exec)
# -----------------------------------------------------------------------------
DB_CONTAINER="ticketz-docker-acme-postgres-1"
DB_NAME="ticketz"
DB_USER="ticketz"

# -----------------------------------------------------------------------------
# Ações padrão
# -----------------------------------------------------------------------------
# DO_BACKUP=1       -> cria backup local timestamped
# DO_MOVE=1         -> move arquivos para quarentena
# PUSH_REMOTE=1     -> faz upload via rclone
# UPDATE_DB_AFTER_PUSH=1 -> atualiza mediaUrl no banco para URL pública do S3
DO_BACKUP=0
DO_MOVE=1
PUSH_REMOTE=1
UPDATE_DB_AFTER_PUSH=1

# -----------------------------------------------------------------------------
# rclone
# -----------------------------------------------------------------------------
# RCLONE_REMOTE: destino no formato <remote>:<bucket>/<path>
RCLONE_REMOTE="seu_remote:seu_bucket/caminho/para/media"
# RCLONE_CONFIG: caminho do arquivo rclone.conf do usuário
RCLONE_CONFIG="/home/ubuntu/.config/rclone/rclone.conf"

# -----------------------------------------------------------------------------
# URL pública do S3 / Backblaze B2
# -----------------------------------------------------------------------------
# Usada para reescrever mediaUrl no banco após upload.
# NÃO deve terminar com barra.
S3_PUBLIC_URL="https://sua-url-publica.example.com/bucket/caminho"

# -----------------------------------------------------------------------------
# Comportamento adicional
# -----------------------------------------------------------------------------
DELETE_QUAR_AFTER_PUSH=1
LIMIT=0       # 0 = todos os candidatos
PRUNE_KEEP=5  # manter últimos N backups locais (0 = desabilitar)
VERBOSE=1
